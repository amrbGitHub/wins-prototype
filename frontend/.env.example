# Backend API base URL
# Leave empty (or omit) for local dev — Vite proxy handles /api -> localhost:8787
# In production: set to your Render backend URL (e.g. https://wins-backend.onrender.com)
VITE_API_BASE_URL=

# Supabase — get from Dashboard > Settings > API (under "Project URL" and "anon key")
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
