# Copy this to `.env` and fill in your real values.
# `.env` is gitignored; `.env.example` is the safe-to-commit template.

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Ollama (LLM) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ── ElevenLabs TTS (optional) ───────────────────────────────────────────────
# Get a free API key from https://elevenlabs.io (10,000 chars/month free tier).
# When set, the app uses ElevenLabs for voice mode; when blank, falls back to
# the in-browser Kokoro 82M model. Voice ID and model are optional overrides.
#
# Default voice (21m00Tcm4TlvDq8ikWAM) is "Rachel" — warm female voice.
# Other free-tier voice IDs:
#   EXAVITQu4vr4xnSDxMaL — Bella   (soft female)
#   AZnzlk1XvdvUeBnXmlld — Domi    (energetic female)
#   pNInz6obpgDQGcFmaJgB — Adam    (deep male)
#   ErXwobaYiN019PkySvjV — Antoni  (well-rounded male)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
