# Ollama configuration
OLLAMA_MODEL=llama3.2
# In production: set this to your Cloudflare tunnel URL (e.g. https://abc123.trycloudflare.com/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Port (Render sets this automatically; locally defaults to 8787)
PORT=8787

# CORS: comma-separated list of allowed frontend origins
# In production: set to your Vercel URL (e.g. https://your-app.vercel.app)
ALLOWED_ORIGINS=http://localhost:5173

# Supabase — get from Dashboard > Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
