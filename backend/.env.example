# Copy this to `.env` and fill in your real values.
# `.env` is gitignored; `.env.example` is the safe-to-commit template.

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ── LC chat gateway (Anthropic-compatible LLM) ──────────────────────────────
# Works with Anthropic directly OR any Anthropic-compatible provider
# (e.g. DeepSeek's https://api.deepseek.com/anthropic endpoint).
#
# ANTHROPIC_BASE_URL — leave unset for Anthropic's default URL, or point to
#   a different provider's Anthropic-compatible base.
# ANTHROPIC_API_KEY  — required.
# ANTHROPIC_MODEL    — main chat model (LC voice). Defaults to a Claude Haiku
#   ID for safety; in this project we run DeepSeek v4 Pro.
# SUMMARY_MODEL      — model used for the per-turn summary updater only. This
#   is a bounded JSON-out task, so we route it to a faster/cheaper model
#   (DeepSeek v4 Flash) while keeping Pro for the conversational gateway.
#   Unset → summary updater uses ANTHROPIC_MODEL too.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=deepseek-v4-pro
SUMMARY_MODEL=deepseek-v4-flash

# ── PII pseudonym registry encryption key (REQUIRED) ────────────────────────
# Master AES-256 key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: losing this key permanently bricks every encrypted row in the
# pseudonym_registry, pseudonym_summaries, and conversation_summaries tables.
# Dev and prod sharing the same Supabase project MUST share the same key.
PSEUDONYM_ENCRYPTION_KEY=

# ── ElevenLabs TTS (optional) ───────────────────────────────────────────────
# Get a free API key from https://elevenlabs.io (10,000 chars/month free tier).
# When set, the app uses ElevenLabs for voice mode; when blank, falls back to
# the in-browser Kokoro 82M model. Voice ID and model are optional overrides.
#
# Default voice (21m00Tcm4TlvDq8ikWAM) is "Rachel" — warm female voice.
# Other free-tier voice IDs:
#   EXAVITQu4vr4xnSDxMaL — Bella   (soft female)
#   AZnzlk1XvdvUeBnXmlld — Domi    (energetic female)
#   pNInz6obpgDQGcFmaJgB — Adam    (deep male)
#   ErXwobaYiN019PkySvjV — Antoni  (well-rounded male)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
